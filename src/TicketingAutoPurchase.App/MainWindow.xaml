<Window x:Class="TicketingAutoPurchase.App.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         mc:Ignorable="d"
         Title="Ticketing Auto Purchase" Height="420" Width="760"
         MinHeight="360" MinWidth="640">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22" FontWeight="SemiBold" Text="티켓팅 자동 구매 - 기본 세팅" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Text="이벤트 키워드" FontWeight="SemiBold" />
            <TextBox Margin="0,6,0,0" Height="32" Text="{Binding EventKeyword, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <TextBlock Text="예매 URL" FontWeight="SemiBold" />
            <TextBox Margin="0,6,0,0" Height="32" Text="{Binding TargetUrl, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,20,0,0" Orientation="Horizontal">
            <Button Content="자동화 실행" Width="140" Height="34" Command="{Binding StartAutomationCommand}" />
            <TextBlock Margin="12,8,0,0" VerticalAlignment="Center" Text="{Binding StatusMessage}" />
        </StackPanel>

        <Border Grid.Row="4" Margin="0,20,0,0" Padding="14" CornerRadius="8" BorderThickness="1" BorderBrush="#D1D5DB" Background="#F9FAFB">
            <TextBlock TextWrapping="Wrap" Text="{Binding LastRunSummary}" />
        </Border>
    </Grid>
</Window>
