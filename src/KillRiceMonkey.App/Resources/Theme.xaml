    <Color x:Key="InputStrokeColor">#FF2A365D</Color>
    <Color x:Key="PrimaryTextColor">#FFF0F2F8</Color>
    <Color x:Key="MutedTextColor">#FF96A2C7</Color>
    <Color x:Key="AccentColor">#FF38BDF8</Color>
    <Color x:Key="AccentDeepColor">#FF8B5CF6</Color>
    <Color x:Key="AccentSoftColor">#2238BDF8</Color>
    <Color x:Key="SuccessColor">#FF10B981</Color>
    <Color x:Key="SuccessSoftColor">#2210B981</Color>
    <Color x:Key="DangerColor">#FFEF4444</Color>
    <Color x:Key="DangerSoftColor">#22EF4444</Color>
    <Color x:Key="WarningColor">#FFF2C14E</Color>
