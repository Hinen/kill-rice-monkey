    <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
        <Grid Height="{TemplateBinding Height}">
            <Border Margin="2,3"
                    Background="{StaticResource SurfaceAltBrush}"
                    CornerRadius="{StaticResource ScrollBarThumbCornerRadius}" />
            <Track x:Name="PART_Track"
                   Orientation="Horizontal">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                  Style="{StaticResource DarkScrollBarPageButtonStyle}" />
