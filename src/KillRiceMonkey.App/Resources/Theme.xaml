        <Setter Property="Height" Value="50" />
        <Setter Property="Padding" Value="22,12" />
        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
