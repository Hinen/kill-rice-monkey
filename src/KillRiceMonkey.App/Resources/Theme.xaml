    <Color x:Key="HeroCalloutStrokeColor">#2638BDF8</Color>
    <Color x:Key="SummarySurfaceColor">#D9182039</Color>
    <Color x:Key="OrbColor">#2A38BDF8</Color>
    <Color x:Key="OrbSecondaryColor">#268B5CF6</Color>
    <Color x:Key="GlossHighlightColor">#16FFFFFF</Color>
    <Color x:Key="GlossAccentColor">#0D38BDF8</Color>
    <Color x:Key="GlossFadeColor">#00FFFFFF</Color>
    <Color x:Key="ShadowColor">#FF000000</Color>
    <Color x:Key="SelectionColor">#3338BDF8</Color>
    <Color x:Key="InputHoverStrokeColor">#FF58C8FF</Color>
    <Color x:Key="ProgressTrackColor">#1838BDF8</Color>
    <Color x:Key="GlassSurfaceColor">#CC141A2E</Color>
    <Color x:Key="GlassSurfaceAltColor">#B81C2340</Color>
    <Color x:Key="GlassButtonColor">#4016223D</Color>
    <Color x:Key="GlassButtonHoverColor">#2438BDF8</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource CanvasColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="StrokeBrush" Color="{StaticResource StrokeColor}" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="InputStrokeBrush" Color="{StaticResource InputStrokeColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentDeepBrush" Color="{StaticResource AccentDeepColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="{StaticResource SuccessSoftColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{StaticResource DangerSoftColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="{StaticResource WarningSoftColor}" />
    <SolidColorBrush x:Key="HeroPanelStrokeBrush" Color="{StaticResource HeroPanelStrokeColor}" />
    <SolidColorBrush x:Key="HeroChipBrush" Color="{StaticResource HeroChipColor}" />
    <SolidColorBrush x:Key="HeroChipStrokeBrush" Color="{StaticResource HeroChipStrokeColor}" />
    <SolidColorBrush x:Key="HeroBodyTextBrush" Color="{StaticResource HeroBodyTextColor}" />
    <SolidColorBrush x:Key="HeroMutedTextBrush" Color="{StaticResource HeroMutedTextColor}" />
    <SolidColorBrush x:Key="HeroSoftCardBrush" Color="{StaticResource HeroSoftCardColor}" />
    <SolidColorBrush x:Key="HeroSoftCardStrokeBrush" Color="{StaticResource HeroSoftCardStrokeColor}" />
    <SolidColorBrush x:Key="HeroCalloutBrush" Color="{StaticResource HeroCalloutColor}" />
    <SolidColorBrush x:Key="HeroCalloutStrokeBrush" Color="{StaticResource HeroCalloutStrokeColor}" />
    <SolidColorBrush x:Key="SummarySurfaceBrush" Color="{StaticResource SummarySurfaceColor}" />
    <SolidColorBrush x:Key="OrbBrush" Color="{StaticResource OrbColor}" />
    <SolidColorBrush x:Key="OrbSecondaryBrush" Color="{StaticResource OrbSecondaryColor}" />
    <SolidColorBrush x:Key="SelectionHighlightBrush" Color="{StaticResource SelectionColor}" />
    <SolidColorBrush x:Key="InputHoverStrokeBrush" Color="{StaticResource InputHoverStrokeColor}" />
    <SolidColorBrush x:Key="ProgressTrackBrush" Color="{StaticResource ProgressTrackColor}" />
    <SolidColorBrush x:Key="GlassSurfaceBrush" Color="{StaticResource GlassSurfaceColor}" />
    <SolidColorBrush x:Key="GlassSurfaceAltBrush" Color="{StaticResource GlassSurfaceAltColor}" />
    <SolidColorBrush x:Key="GlassButtonBrush" Color="{StaticResource GlassButtonColor}" />
    <SolidColorBrush x:Key="GlassButtonHoverBrush" Color="{StaticResource GlassButtonHoverColor}" />

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF38BDF8" Offset="0" />
        <GradientStop Color="#FF8B5CF6" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentHoverGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF67D6FF" Offset="0" />
        <GradientStop Color="#FFB094FF" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource HeroStartColor}" Offset="0" />
        <GradientStop Color="{StaticResource HeroMiddleColor}" Offset="0.58" />
        <GradientStop Color="{StaticResource HeroEndColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlossBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource GlossHighlightColor}" Offset="0" />
        <GradientStop Color="{StaticResource GlossAccentColor}" Offset="0.45" />
        <GradientStop Color="{StaticResource GlossFadeColor}" Offset="1" />
    </LinearGradientBrush>

    <DropShadowEffect x:Key="CardShadowEffect"
                      BlurRadius="36"
                      ShadowDepth="0"
                      Opacity="0.18"
                      Color="{StaticResource ShadowColor}" />

    <CornerRadius x:Key="InputCornerRadius">16</CornerRadius>
    <CornerRadius x:Key="PopupCornerRadius">16</CornerRadius>
    <CornerRadius x:Key="CalendarButtonCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="ScrollBarThumbCornerRadius">999</CornerRadius>

    <FontFamily x:Key="AppFontFamily">./Resources/Fonts/#Pretendard</FontFamily>

