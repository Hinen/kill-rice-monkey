<Window x:Class="KillRiceMonkey.App.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         mc:Ignorable="d"
         Title="Kill Rice Monkey"
         Width="1180"
         Height="760"
         MinWidth="920"
         MinHeight="640"
         WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="StatusBadgeBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="12,7" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Background" Value="#FFFCE8C8" />
                    <Setter Property="BorderBrush" Value="#FFE2A93B" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSuccessStatus}" Value="True">
                    <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsErrorStatus}" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AccentDeepBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Foreground" Value="#FF8B5A00" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSuccessStatus}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsErrorStatus}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootContent"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.45" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="420" Height="420" Fill="{StaticResource OrbBrush}" Canvas.Left="-140" Canvas.Top="-150" />
            <Ellipse Width="360" Height="360" Fill="#26BBD8FF" Canvas.Right="-120" Canvas.Top="120" />
        </Canvas>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalContentAlignment="Stretch">
            <Grid x:Name="RootContent" Margin="32" Opacity="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="KILL RICE MONKEY / DESKTOP HELPER" />
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource SectionTitleTextStyle}" Text="티켓팅 자동화 컨트롤 센터" />
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource StatusBadgeBorderStyle}" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource StatusBadgeTextStyle}" Text="{Binding StatusMessage}" />
                    </Border>
                </Grid>

                <Grid Grid.Row="2" VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.02*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="1.28*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource SurfaceCardStyle}" Background="{StaticResource HeroBackgroundBrush}" BorderBrush="#1FFFFFFF">
                        <Grid>
                            <Rectangle RadiusX="24" RadiusY="24" Fill="{StaticResource GlossBrush}" Opacity="0.55" />
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Padding="12,6" CornerRadius="999" Background="#1CFFFFFF" BorderBrush="#26FFFFFF" BorderThickness="1" HorizontalAlignment="Left">
                                    <TextBlock Style="{StaticResource EyebrowTextStyle}" Foreground="#E5FFFFFF" Text="CONTROL DASHBOARD" />
                                </Border>

                                <TextBlock Grid.Row="1"
                                           Margin="0,22,0,0"
                                           Style="{StaticResource HeroTitleTextStyle}">
                                    <Run Text="{Binding HotkeyText}" />
                                    <Run Text=" 한 번으로" />
                                    <LineBreak />
                                    <Run Text="실행 흐름을 시작합니다" />
                                </TextBlock>

                                <TextBlock Grid.Row="3"
                                           Style="{StaticResource HelperTextStyle}"
                                           Foreground="#D6E3F8"
                                           TextWrapping="Wrap"
                                           Text="사용자가 직접 연 사이트를 기준으로, 이미지 단계 실행을 빠르게 시작하는 데 초점을 맞춘 데스크톱 헬퍼입니다. 시각 구조를 대시보드형으로 재구성해 상태 확인과 조작 포인트를 더 또렷하게 정리했습니다." />

                                <Grid Grid.Row="4" Margin="0,28,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Style="{StaticResource SoftCardStyle}" Background="#14FFFFFF" BorderBrush="#1FFFFFFF">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontFamily="Bahnschrift SemiCondensed" FontSize="26" Foreground="White" Text="01" />
                                            <StackPanel Grid.Column="2">
                                                <TextBlock FontFamily="Bahnschrift SemiCondensed" FontSize="16" FontWeight="SemiBold" Foreground="White" Text="템플릿 기반 제어" />
                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource HelperTextStyle}" Foreground="#C9D8F4" Text="Yes24, Booth, NOL, Melon, Custom 템플릿을 한 화면에서 전환합니다." />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2" Style="{StaticResource SoftCardStyle}" Background="#14FFFFFF" BorderBrush="#1FFFFFFF">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontFamily="Bahnschrift SemiCondensed" FontSize="26" Foreground="White" Text="02" />
                                            <StackPanel Grid.Column="2">
                                                <TextBlock FontFamily="Bahnschrift SemiCondensed" FontSize="16" FontWeight="SemiBold" Foreground="White" Text="실행 상태 피드백" />
                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource HelperTextStyle}" Foreground="#C9D8F4" Text="실행 상태와 마지막 결과를 분리해 확인 흐름을 단순화했습니다." />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="4" Style="{StaticResource SoftCardStyle}" Background="#14FFFFFF" BorderBrush="#1FFFFFFF">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontFamily="Bahnschrift SemiCondensed" FontSize="26" Foreground="White" Text="03" />
                                            <StackPanel Grid.Column="2">
                                                <TextBlock FontFamily="Bahnschrift SemiCondensed" FontSize="16" FontWeight="SemiBold" Foreground="White" Text="명확한 실행 가이드" />
                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource HelperTextStyle}" Foreground="#C9D8F4" Text="핫키와 파일명 규칙을 별도 정보 카드로 분리해 실수 가능성을 줄였습니다." />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Border Grid.Row="5" Margin="0,24,0,0" Padding="16" CornerRadius="18" Background="#16FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                                    <TextBlock Style="{StaticResource HelperTextStyle}" Foreground="#F4F7FF" Text="실행은 언제나 사용자 액션에서 시작되며, 현재 창은 설정 집중도와 상태 가독성을 높이는 방향으로 재구성되어 있습니다." />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2" VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource SurfaceCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="20" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="실행 설정" />
                                        <TextBlock Margin="0,8,0,0" Style="{StaticResource HelperTextStyle}" Text="기존 MVVM 바인딩은 유지하고, 빠르게 읽히는 입력 카드 구조로 정리했습니다." />
                                    </StackPanel>

                                    <Border Grid.Column="1" Padding="12,6" CornerRadius="999" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" VerticalAlignment="Top">
                                        <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="READY" />
                                    </Border>
                                </Grid>

                                <ProgressBar Grid.Row="1"
                                             Margin="0,18,0,0"
                                             Style="{StaticResource ThinProgressBarStyle}"
                                             IsIndeterminate="True"
                                             Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <Grid Grid.Row="3">
                                     <Grid.RowDefinitions>
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="20" />
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="20" />
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="20" />
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="20" />
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="20" />
                                         <RowDefinition Height="Auto" />
                                     </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="실행 템플릿" />
                                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                  ItemsSource="{Binding TemplateOptions}"
                                                  SelectedItem="{Binding SelectedTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   Style="{StaticResource HelperTextStyle}"
                                                   Text="실행 전 템플릿을 반드시 선택해야 합니다." />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="매칭 임계값" />
                                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                 Text="{Binding MatchThreshold, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="버튼 이미지 폴더 경로" />
                                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                 IsEnabled="{Binding IsImageDirectoryEditable}"
                                                 Text="{Binding ImageDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   Style="{StaticResource HelperTextStyle}"
                                                    Text="Template가 Yes24, Booth, Melon이면 기본 폴더가 자동으로 고정되고, NOL/Melon은 이미지 폴더를 사용하지 않으며, Custom일 때만 직접 수정할 수 있습니다." />
                                     </StackPanel>

                                     <StackPanel Grid.Row="4" Grid.ColumnSpan="3">
                                         <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="단계별 제한 시간(초)" />
                                         <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                  Width="220"
                                                  HorizontalAlignment="Left"
                                                  Text="{Binding StepTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                     </StackPanel>

                                     <Border Grid.Row="6"
                                             Grid.ColumnSpan="3"
                                             Style="{StaticResource SoftCardStyle}"
                                             Visibility="{Binding IsNolTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                         <Grid>
                                             <Grid.RowDefinitions>
                                                 <RowDefinition Height="Auto" />
                                                 <RowDefinition Height="16" />
                                                 <RowDefinition Height="Auto" />
                                             </Grid.RowDefinitions>
                                             <Grid.ColumnDefinitions>
                                                 <ColumnDefinition Width="*" />
                                                 <ColumnDefinition Width="20" />
                                                 <ColumnDefinition Width="220" />
                                             </Grid.ColumnDefinitions>

                                              <StackPanel Grid.ColumnSpan="3">
                                                  <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="NOL 화면 입력값" />
                                                  <TextBlock Margin="0,8,0,0"
                                                             Style="{StaticResource HelperTextStyle}"
                                                             Text="먼저 remote debug 브라우저를 열고 로그인한 뒤, 관람일과 회차를 선택해 자동화를 실행합니다." />
                                              </StackPanel>

                                             <StackPanel Grid.Row="2">
                                                 <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="관람일" />
                                                 <DatePicker SelectedDate="{Binding DesiredDate, UpdateSourceTrigger=PropertyChanged}"
                                                             SelectedDateFormat="Long"
                                                             Style="{StaticResource InputDatePickerStyle}" />
                                             </StackPanel>

                                             <StackPanel Grid.Row="2" Grid.Column="2">
                                                 <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="회차" />
                                                 <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                           Text="{Binding DesiredRound, UpdateSourceTrigger=PropertyChanged}" />
                                             </StackPanel>
                                         </Grid>
                                      </Border>

                                      <Border Grid.Row="6"
                                              Grid.ColumnSpan="3"
                                              Style="{StaticResource SoftCardStyle}"
                                              Visibility="{Binding IsMelonTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                          <Grid>
                                              <Grid.RowDefinitions>
                                                  <RowDefinition Height="Auto" />
                                                  <RowDefinition Height="16" />
                                                  <RowDefinition Height="Auto" />
                                              </Grid.RowDefinitions>
                                              <Grid.ColumnDefinitions>
                                                  <ColumnDefinition Width="*" />
                                                  <ColumnDefinition Width="20" />
                                                  <ColumnDefinition Width="220" />
                                              </Grid.ColumnDefinitions>

                                              <StackPanel Grid.ColumnSpan="3">
                                                  <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Melon 화면 입력값" />
                                                  <TextBlock Margin="0,8,0,0"
                                                             Style="{StaticResource HelperTextStyle}"
                                                             Text="먼저 remote debug 브라우저를 열고 로그인한 뒤, 관람일과 시간을 선택해 자동화를 실행합니다." />
                                              </StackPanel>

                                              <StackPanel Grid.Row="2">
                                                   <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="관람일" />
                                                   <DatePicker SelectedDate="{Binding DesiredDate, UpdateSourceTrigger=PropertyChanged}"
                                                               SelectedDateFormat="Long"
                                                               Style="{StaticResource InputDatePickerStyle}" />
                                              </StackPanel>

                                              <StackPanel Grid.Row="2" Grid.Column="2">
                                                  <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="시간" />
                                                  <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                           Text="{Binding DesiredTime, UpdateSourceTrigger=PropertyChanged}" />
                                              </StackPanel>
                                          </Grid>
                                      </Border>

                                      <Grid Grid.Row="8" Grid.ColumnSpan="3">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="Auto" />
                                             <ColumnDefinition Width="16" />
                                             <ColumnDefinition Width="*" />
                                         </Grid.ColumnDefinitions>

                                         <StackPanel Width="220">
                                             <Button Margin="0,0,0,12"
                                                     Style="{StaticResource PrimaryButtonStyle}"
                                                     Command="{Binding LaunchNolRemoteDebugCommand}"
                                                     Visibility="{Binding IsNolTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                 <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                     <TextBlock FontFamily="Bahnschrift SemiCondensed" FontSize="14" Text="OPEN" />
                                                     <TextBlock Margin="8,0,0,0" FontSize="15" Text="NOL Remote Debug 열기" />
                                                 </StackPanel>
                                             </Button>

                                              <Button Margin="0,0,0,12"
                                                      Style="{StaticResource PrimaryButtonStyle}"
                                                      Command="{Binding PrepareNolAutomationCommand}"
                                                      Visibility="{Binding IsNolTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                 <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                     <TextBlock FontFamily="Bahnschrift SemiCondensed" FontSize="14" Text="READY" />
                                                     <TextBlock Margin="8,0,0,0" FontSize="15" Text="NOL 준비" />
                                                  </StackPanel>
                                              </Button>

                                              <Button Margin="0,0,0,12"
                                                      Style="{StaticResource PrimaryButtonStyle}"
                                                      Command="{Binding LaunchMelonRemoteDebugCommand}"
                                                      Visibility="{Binding IsMelonTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                      <TextBlock FontFamily="Bahnschrift SemiCondensed" FontSize="14" Text="OPEN" />
                                                      <TextBlock Margin="8,0,0,0" FontSize="15" Text="Melon Remote Debug 열기" />
                                                  </StackPanel>
                                              </Button>

                                              <Button Margin="0,0,0,12"
                                                      Style="{StaticResource PrimaryButtonStyle}"
                                                      Command="{Binding PrepareMelonAutomationCommand}"
                                                      Visibility="{Binding IsMelonTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                      <TextBlock FontFamily="Bahnschrift SemiCondensed" FontSize="14" Text="READY" />
                                                      <TextBlock Margin="8,0,0,0" FontSize="15" Text="Melon 준비" />
                                                  </StackPanel>
                                              </Button>

                                              <Button Width="176"
                                                      Style="{StaticResource PrimaryButtonStyle}"
                                                      Command="{Binding StartAutomationCommand}">
                                                 <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                     <TextBlock FontFamily="Bahnschrift SemiCondensed" FontSize="14" Foreground="White" Text="RUN" />
                                                     <TextBlock Margin="8,0,0,0" FontSize="15" Foreground="White" Text="자동화 실행" />
                                                 </StackPanel>
                                             </Button>
                                         </StackPanel>

                                        <Border Grid.Column="2" Style="{StaticResource SoftCardStyle}" VerticalAlignment="Stretch">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                    <Setter Property="Fill" Value="#FFE2A93B" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSuccessStatus}" Value="True">
                                                                    <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsErrorStatus}" Value="True">
                                                                    <Setter Property="Fill" Value="{StaticResource DangerBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="CURRENT STATE" />
                                                    <TextBlock Margin="0,6,0,0" FontFamily="Bahnschrift SemiCondensed" FontSize="20" FontWeight="SemiBold" Text="{Binding StatusMessage}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                         <Border Grid.Row="2" Style="{StaticResource SurfaceCardStyle}">
                             <StackPanel>
                                 <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="실행 가이드" />
                                  <TextBlock Margin="0,14,0,0" Style="{StaticResource HelperTextStyle}" TextWrapping="Wrap">
                                      <Run Text="전역 핫키(" />
                                      <Run Text="{Binding HotkeyText}" />
                                      <Run Text=")로 실행 가능. 이미지 모드는 파일명 규칙: 숫자.png 또는 숫자-normal.png / 숫자-active.png, NOL/Melon은 먼저 remote debug 브라우저를 열고 로그인한 뒤 자동화를 실행합니다." />
                                   </TextBlock>
                               </StackPanel>
                           </Border>

                        <Border Grid.Row="4" Style="{StaticResource SurfaceCardStyle}" VerticalAlignment="Stretch">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="마지막 실행 요약" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource EyebrowTextStyle}" VerticalAlignment="Center" Text="LATEST" />
                                </Grid>

                                <Border Grid.Row="2" Style="{StaticResource SoftCardStyle}" Background="#FFF8FAFD">
                                    <TextBlock TextWrapping="Wrap"
                                               LineHeight="24"
                                               FontSize="14"
                                               Text="{Binding LastRunSummary}" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
