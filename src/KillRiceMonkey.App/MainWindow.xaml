<Window x:Class="KillRiceMonkey.App.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         mc:Ignorable="d"
         Title="Ticketing Auto Purchase" Height="460" Width="760"
         MinHeight="360" MinWidth="640">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22" FontWeight="SemiBold" Text="티켓팅 자동 구매 - 이미지 단계 실행" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Text="버튼 이미지 폴더 경로" FontWeight="SemiBold" />
            <TextBox Margin="0,6,0,0" Height="32" Text="{Binding ImageDirectory, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="매칭 임계값(0~1)" FontWeight="SemiBold" />
                <TextBox Margin="0,6,0,0" Height="32" Text="{Binding MatchThreshold, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="단계별 제한 시간(초)" FontWeight="SemiBold" />
                <TextBox Margin="0,6,0,0" Height="32" Text="{Binding StepTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Margin="0,20,0,0" Orientation="Horizontal">
            <Button Content="자동화 실행" Width="140" Height="34" Command="{Binding StartAutomationCommand}" />
            <TextBlock Margin="12,8,0,0" VerticalAlignment="Center" Text="{Binding StatusMessage}" />
        </StackPanel>

        <TextBlock Grid.Row="4" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#374151"
                   Text="{Binding HotkeyText, StringFormat=전역 핫키({0})로 active 진입 가능. 파일명 규칙: 숫자-normal.png / 숫자-active.png}" />

        <Border Grid.Row="5" Margin="0,20,0,0" Padding="14" CornerRadius="8" BorderThickness="1" BorderBrush="#D1D5DB" Background="#F9FAFB">
            <TextBlock TextWrapping="Wrap" Text="{Binding LastRunSummary}" />
        </Border>
    </Grid>
</Window>
