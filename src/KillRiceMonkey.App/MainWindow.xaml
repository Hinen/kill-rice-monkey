<Window x:Class="KillRiceMonkey.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Kill Rice Monkey"
        Width="1024"
        Height="680"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="StateBadgeBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,6" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSuccessStatus}" Value="True">
                    <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsErrorStatus}" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StateBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSuccessStatus}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsErrorStatus}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionIconPathStyle" TargetType="Path">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Stroke" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
            <Setter Property="MinWidth" Value="126" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReadyActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasSelectedTemplate}" Value="False">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RunActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="156" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSelectedTemplate}" Value="False">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResultCardBorderStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSuccessStatus}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsErrorStatus}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootContent"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.4" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="360"
                     Height="360"
                     Fill="{StaticResource OrbBrush}"
                     Canvas.Left="-120"
                     Canvas.Top="-140" />
            <Ellipse Width="320"
                     Height="320"
                     Fill="{StaticResource OrbSecondaryBrush}"
                     Canvas.Right="-70"
                     Canvas.Top="60" />
            <Ellipse Width="220"
                     Height="220"
                     Fill="{StaticResource AccentSoftBrush}"
                     Opacity="0.38"
                     Canvas.Left="180"
                     Canvas.Bottom="-40" />
            <Ellipse Width="180"
                     Height="180"
                     Fill="{StaticResource AccentSoftBrush}"
                     Opacity="0.22"
                     Canvas.Right="140"
                     Canvas.Bottom="10" />
        </Canvas>

        <Grid x:Name="RootContent" Margin="18" Opacity="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource SurfaceCardStyle}"
                    Padding="16,0"
                    Background="{StaticResource GlassSurfaceBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Viewbox Width="20" Height="20" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="{StaticResource ZapIcon}"
                                      Fill="{StaticResource AccentSoftBrush}"
                                      Stroke="{StaticResource AccentBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Canvas>
                        </Viewbox>

                        <TextBlock Grid.Column="2"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Text="KILL RICE MONKEY" />

                        <Border Grid.Column="4"
                                Padding="10,4"
                                CornerRadius="10"
                                Background="{StaticResource HeroChipBrush}"
                                BorderBrush="{StaticResource HeroChipStrokeBrush}"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="14"
                                           VerticalAlignment="Center"
                                           Text="⚡" />
                                <TextBlock Margin="6,0,0,0"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Text="{Binding HotkeyText}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Column="1"
                            Style="{StaticResource StateBadgeBorderStyle}"
                            VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource StateBadgeTextStyle}"
                                   Text="READY" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource SurfaceCardStyle}" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ProgressBar Grid.Row="0"
                                     Style="{StaticResource ThinProgressBarStyle}"
                                     IsIndeterminate="True"
                                     Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="0.85*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="0.85*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="1.45*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}"
                                           Text="템플릿" />
                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                          ItemsSource="{Binding TemplateOptions}"
                                          SelectedItem="{Binding SelectedTemplate, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}"
                                           Text="매칭 임계값" />
                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                         Text="{Binding MatchThreshold, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}"
                                           Text="타임아웃(초)" />
                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                         Text="{Binding StepTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="6">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}"
                                           Text="이미지 폴더" />
                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                         IsEnabled="{Binding IsImageDirectoryEditable}"
                                         Text="{Binding ImageDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="4">
                            <Border
                                    Style="{StaticResource SoftCardStyle}"
                                    Visibility="{Binding IsNolTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.25*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="0.75*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}"
                                                   Text="관람일" />
                                        <DatePicker Style="{StaticResource InputDatePickerStyle}"
                                                    SelectedDate="{Binding DesiredDate, UpdateSourceTrigger=PropertyChanged}"
                                                    SelectedDateFormat="Short" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}"
                                                   Text="회차" />
                                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                 Text="{Binding DesiredRound, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border
                                    Style="{StaticResource SoftCardStyle}"
                                    Visibility="{Binding IsMelonTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="0.8*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}"
                                                   Text="관람일" />
                                        <DatePicker Style="{StaticResource InputDatePickerStyle}"
                                                    SelectedDate="{Binding DesiredDate, UpdateSourceTrigger=PropertyChanged}"
                                                    SelectedDateFormat="Short" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}"
                                                   Text="시간/회차" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <ComboBox Grid.Column="0"
                                                      Style="{StaticResource InputComboBoxStyle}"
                                                      ItemsSource="{Binding HourOptions}"
                                                      SelectedItem="{Binding MelonHour, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemStringFormat="{}{0:D2}" />

                                            <ComboBox Grid.Column="2"
                                                      Style="{StaticResource InputComboBoxStyle}"
                                                      ItemsSource="{Binding MinuteOptions}"
                                                      SelectedItem="{Binding MelonMinute, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemStringFormat="{}{0:D2}" />
                                        </Grid>
                                    </StackPanel>

                                    <TextBox Grid.ColumnSpan="3"
                                             Visibility="Collapsed"
                                             Text="{Binding DesiredTime, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Border>

                        </Grid>

                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Command="{Binding LaunchNolRemoteDebugCommand}"
                                    Visibility="{Binding IsNolTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Viewbox Width="15" Height="15" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Style="{StaticResource ActionIconPathStyle}"
                                                  Data="{StaticResource ExternalLinkIcon}" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock VerticalAlignment="Center" Text="OPEN" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="0"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Command="{Binding LaunchMelonRemoteDebugCommand}"
                                    Visibility="{Binding IsMelonTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Viewbox Width="15" Height="15" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Style="{StaticResource ActionIconPathStyle}"
                                                  Data="{StaticResource ExternalLinkIcon}" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock VerticalAlignment="Center" Text="OPEN" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Style="{StaticResource ReadyActionButtonStyle}"
                                    Command="{Binding PrepareNolAutomationCommand}"
                                    Visibility="{Binding IsNolTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Viewbox Width="15" Height="15" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Style="{StaticResource ActionIconPathStyle}"
                                                  Data="{StaticResource ShieldCheckIcon}" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock VerticalAlignment="Center" Text="READY" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Style="{StaticResource ReadyActionButtonStyle}"
                                    Command="{Binding PrepareMelonAutomationCommand}"
                                    Visibility="{Binding IsMelonTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Viewbox Width="15" Height="15" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Style="{StaticResource ActionIconPathStyle}"
                                                  Data="{StaticResource ShieldCheckIcon}" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock VerticalAlignment="Center" Text="READY" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="4"
                                    Style="{StaticResource RunActionButtonStyle}"
                                    Command="{Binding StartAutomationCommand}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Viewbox Width="15" Height="15" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Style="{StaticResource ActionIconPathStyle}"
                                                  Data="{StaticResource PlayIcon}" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock VerticalAlignment="Center" Text="RUN" />
                                </StackPanel>
                            </Button>

                            <Border Grid.Column="6"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource SoftCardStyle}"
                                    Padding="12,8"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="{StaticResource ZapIcon}"
                                                  Fill="{StaticResource AccentSoftBrush}"
                                                  Stroke="{StaticResource AccentBrush}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round" />
                                        </Canvas>
                                    </Viewbox>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource EyebrowTextStyle}"
                                                   Text="STATUS" />
                                        <TextBlock Margin="0,2,0,0"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding StatusMessage}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource ResultCardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Viewbox Width="18" Height="18" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="{StaticResource ShieldCheckIcon}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Stroke" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Fill" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSuccessStatus}" Value="True">
                                                        <Setter Property="Stroke" Value="{StaticResource SuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsErrorStatus}" Value="True">
                                                        <Setter Property="Stroke" Value="{StaticResource DangerBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter Property="Stroke" Value="{StaticResource WarningBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Canvas>
                            </Viewbox>

                            <TextBlock Grid.Column="2"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Text="실행 로그" />

                            <Border Grid.Column="3"
                                    Style="{StaticResource StateBadgeBorderStyle}"
                                    VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource StateBadgeTextStyle}"
                                           Text="LATEST" />
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource SoftCardStyle}"
                                    Background="{StaticResource SummarySurfaceBrush}"
                                    Padding="16,14">
                                <TextBlock FontSize="14"
                                           LineHeight="24"
                                           TextWrapping="Wrap"
                                           Text="{Binding LastRunSummary}" />
                            </Border>

                            <Border Grid.Row="2"
                                    Style="{StaticResource SoftCardStyle}"
                                    Background="{StaticResource SummarySurfaceBrush}"
                                    Padding="16,14">
                                 <ScrollViewer VerticalScrollBarVisibility="Visible"
                                               MaxHeight="200"
                                               ScrollChanged="LogScrollViewer_ScrollChanged">
                                     <ScrollViewer.Resources>
                                         <Style x:Key="LogScrollBarRepeatButtonStyle" TargetType="RepeatButton">
                                             <Setter Property="Focusable" Value="False" />
                                             <Setter Property="Background" Value="Transparent" />
                                             <Setter Property="BorderBrush" Value="Transparent" />
                                             <Setter Property="BorderThickness" Value="0" />
                                             <Setter Property="Template">
                                                 <Setter.Value>
                                                     <ControlTemplate TargetType="RepeatButton">
                                                         <Border Background="{TemplateBinding Background}" />
                                                     </ControlTemplate>
                                                 </Setter.Value>
                                             </Setter>
                                         </Style>

                                         <Style x:Key="LogScrollBarThumbStyle" TargetType="Thumb">
                                             <Setter Property="Template">
                                                 <Setter.Value>
                                                     <ControlTemplate TargetType="Thumb">
                                                         <Border x:Name="ThumbBorder"
                                                                 Margin="1"
                                                                 Background="{StaticResource MutedTextBrush}"
                                                                 BorderBrush="{StaticResource StrokeBrush}"
                                                                 BorderThickness="1"
                                                                 CornerRadius="999"
                                                                 Opacity="0.42" />
                                                         <ControlTemplate.Triggers>
                                                             <Trigger Property="IsMouseOver" Value="True">
                                                                 <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.62" />
                                                             </Trigger>
                                                             <Trigger Property="IsDragging" Value="True">
                                                                 <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                                                                 <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                 <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.74" />
                                                             </Trigger>
                                                             <Trigger Property="IsEnabled" Value="False">
                                                                 <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.25" />
                                                             </Trigger>
                                                         </ControlTemplate.Triggers>
                                                     </ControlTemplate>
                                                 </Setter.Value>
                                             </Setter>
                                         </Style>

                                         <ControlTemplate x:Key="LogVerticalScrollBarTemplate" TargetType="ScrollBar">
                                             <Grid Width="{TemplateBinding Width}" Background="Transparent">
                                                 <Border Margin="1,0"
                                                         Background="{StaticResource InputBackgroundBrush}"
                                                         BorderBrush="{StaticResource StrokeBrush}"
                                                         BorderThickness="1"
                                                         CornerRadius="999"
                                                         Opacity="0.18" />
                                                 <Track x:Name="PART_Track"
                                                        IsDirectionReversed="True">
                                                     <Track.DecreaseRepeatButton>
                                                         <RepeatButton Command="ScrollBar.PageUpCommand"
                                                                       Style="{StaticResource LogScrollBarRepeatButtonStyle}" />
                                                     </Track.DecreaseRepeatButton>
                                                     <Track.Thumb>
                                                         <Thumb Style="{StaticResource LogScrollBarThumbStyle}" />
                                                     </Track.Thumb>
                                                     <Track.IncreaseRepeatButton>
                                                         <RepeatButton Command="ScrollBar.PageDownCommand"
                                                                       Style="{StaticResource LogScrollBarRepeatButtonStyle}" />
                                                     </Track.IncreaseRepeatButton>
                                                 </Track>
                                             </Grid>
                                         </ControlTemplate>

                                         <ControlTemplate x:Key="LogHorizontalScrollBarTemplate" TargetType="ScrollBar">
                                             <Grid Height="{TemplateBinding Height}" Background="Transparent">
                                                 <Border Margin="0,1"
                                                         Background="{StaticResource InputBackgroundBrush}"
                                                         BorderBrush="{StaticResource StrokeBrush}"
                                                         BorderThickness="1"
                                                         CornerRadius="999"
                                                         Opacity="0.18" />
                                                 <Track x:Name="PART_Track"
                                                        Orientation="Horizontal">
                                                     <Track.DecreaseRepeatButton>
                                                         <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                                       Style="{StaticResource LogScrollBarRepeatButtonStyle}" />
                                                     </Track.DecreaseRepeatButton>
                                                     <Track.Thumb>
                                                         <Thumb Style="{StaticResource LogScrollBarThumbStyle}" />
                                                     </Track.Thumb>
                                                     <Track.IncreaseRepeatButton>
                                                         <RepeatButton Command="ScrollBar.PageRightCommand"
                                                                       Style="{StaticResource LogScrollBarRepeatButtonStyle}" />
                                                     </Track.IncreaseRepeatButton>
                                                 </Track>
                                             </Grid>
                                         </ControlTemplate>

                                         <Style TargetType="ScrollBar">
                                             <Setter Property="SnapsToDevicePixels" Value="True" />
                                             <Setter Property="OverridesDefaultStyle" Value="True" />
                                             <Setter Property="Background" Value="Transparent" />
                                             <Setter Property="Width" Value="7" />
                                             <Setter Property="Template" Value="{StaticResource LogVerticalScrollBarTemplate}" />
                                             <Style.Triggers>
                                                 <Trigger Property="Orientation" Value="Horizontal">
                                                     <Setter Property="Height" Value="7" />
                                                     <Setter Property="Width" Value="Auto" />
                                                     <Setter Property="Template" Value="{StaticResource LogHorizontalScrollBarTemplate}" />
                                                 </Trigger>
                                             </Style.Triggers>
                                         </Style>
                                     </ScrollViewer.Resources>
                                     <ItemsControl ItemsSource="{Binding RunLogs}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock FontSize="13"
                                                           LineHeight="22"
                                                           TextWrapping="NoWrap"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Text="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
